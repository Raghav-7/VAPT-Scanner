{
  "name": "universal-vapt-scanner",
  "version": "1.1.0",
  "description": "VAPT Scanner for Web Applications — Comprehensive Security Assessment Tool",
  "main": "server.js",
  "bin": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "build:exe": "caxa --input . --exclude \".git\" \"dist\" --output dist/universal-vapt-scanner.exe -- \"{{caxa}}/node_modules/.bin/node\" \"{{caxa}}/server.js\""
  },
  "dependencies": {
    "axios": "^1.16.1",
    "cheerio": "^1.0.0",
    "exceljs": "^4.4.0",
    "express": "^4.21.0",
    "socket.io": "^4.7.5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "author": "Universal VAPT Team",
  "license": "MIT",
  "pkg": {
    "assets": [
      "public/**/*",
      "scanners/**/*"
    ]
  },
  "devDependencies": {
    "caxa": "^3.0.1",
    "esbuild": "^0.28.0",
    "pkg": "^5.8.1"
  }
}
