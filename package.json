{
  "name": "mendix-vapt-scanner",
  "version": "1.0.0",
  "description": "VAPT Scanner for Mendix Applications — Comprehensive Security Assessment Tool",
  "main": "server.js",
  "bin": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "build:exe": "pkg . --targets node18-win-x64 --out-path dist"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "cheerio": "^1.0.0",
    "exceljs": "^4.4.0",
    "express": "^4.21.0",
    "socket.io": "^4.7.5",
    "uuid": "^10.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "author": "Mendix VAPT Team",
  "license": "MIT",
  "pkg": {
    "assets": [
      "public/**/*",
      "scanners/**/*"
    ]
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  }
}
